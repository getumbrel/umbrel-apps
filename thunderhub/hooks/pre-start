#!/usr/bin/env bash
set -euo pipefail

# ThunderHub 0.18.0 runs as the node user. Existing installs may have
# root-owned data from older packages, so migrate the writable data mount
# before the container starts.
DESIRED_OWNER="1000:1000"
THUNDERHUB_DATA_DIR="${APP_DATA_DIR}/data"

mkdir -p "${THUNDERHUB_DATA_DIR}"

chown -R "${DESIRED_OWNER}" "${THUNDERHUB_DATA_DIR}"
