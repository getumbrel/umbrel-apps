#!/usr/bin/env bash
set -euo pipefail

HOOK_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck disable=SC1091
source "${HOOK_DIR}/common.sh"

APP_DATA_DIR="$(readlink -f "${HOOK_DIR}/.." )"

# Runs before compose up — rebuild image from bundled source (fixes ghcr pull issues).
singularity_build_image "${APP_DATA_DIR}"

echo "SINGULARITY Pool (${SINGULARITY_APP_ID}): pre-start build done"
