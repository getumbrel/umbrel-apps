#!/usr/bin/env bash
# Migrates existing PostgreSQL 17 data (flat layout at /var/lib/postgresql/data)
# to PostgreSQL 18 (versioned layout at /var/lib/postgresql/<major>/docker) in
# place, before the app's compose stack (which runs the db service as a fixed
# non-root UID) starts. The upgrade itself requires root privileges internally
# (pgautoupgrade drops privileges via gosu), which is only available here in
# the pre-start hook, not inside the constrained compose service.
set -euo pipefail

APP_DIR="$(readlink -f "$(dirname "${BASH_SOURCE[0]}")/..")"
APP_DATA_DIR="${APP_DIR}/data"
PG_DATA_DIR="${APP_DATA_DIR}/postgres"

MIGRATION_DONE_FILE="${APP_DATA_DIR}/.pg18_migrated"
MIGRATION_IN_PROGRESS_FILE="${APP_DATA_DIR}/.pg18_migration_in_progress"

PGAUTOUPGRADE_IMAGE="pgautoupgrade/pgautoupgrade:18.4-trixie@sha256:37dfb44476ae3b753d0f305a55912e7442649d7cf020d8c3017acfce210cc062"

# Already migrated (or already a fresh v18+ install) - nothing to do.
if [[ -f "${MIGRATION_DONE_FILE}" ]]; then
  exit 0
fi

# No old-layout PG_VERSION file directly in PG_DATA_DIR means either a fresh
# install (nothing to migrate) or data already in the new nested layout.
# Either way, there is nothing for this migration to do.
if [[ ! -f "${PG_DATA_DIR}/PG_VERSION" ]]; then
  mkdir -p "${PG_DATA_DIR}"
  chown -R 1000:1000 "${PG_DATA_DIR}"
  touch "${MIGRATION_DONE_FILE}"
  exit 0
fi

CURRENT_PG_VERSION="$(cat "${PG_DATA_DIR}/PG_VERSION")"
if [[ "${CURRENT_PG_VERSION}" == "18" ]]; then
  touch "${MIGRATION_DONE_FILE}"
  exit 0
fi

if [[ -f "${MIGRATION_IN_PROGRESS_FILE}" ]]; then
  echo "public-pool-web: PostgreSQL migration already in progress, exiting to prevent loops"
  exit 0
fi
touch "${MIGRATION_IN_PROGRESS_FILE}"

echo "public-pool-web: upgrading PostgreSQL data from v${CURRENT_PG_VERSION} to v18..."

docker run --rm \
  -e POSTGRES_USER="${APP_PUBLIC_POOL_WEB_POSTGRES_USERNAME}" \
  -e POSTGRES_PASSWORD="${APP_PUBLIC_POOL_WEB_POSTGRES_PASSWORD}" \
  -e POSTGRES_DB="${APP_PUBLIC_POOL_WEB_POSTGRES_DBNAME}" \
  -e PGAUTO_ONESHOT=yes \
  -v "${PG_DATA_DIR}:/var/lib/postgresql" \
  "${PGAUTOUPGRADE_IMAGE}"

chown -R 1000:1000 "${PG_DATA_DIR}"

rm -f "${MIGRATION_IN_PROGRESS_FILE}"
touch "${MIGRATION_DONE_FILE}"

echo "public-pool-web: PostgreSQL upgrade to v18 complete."
