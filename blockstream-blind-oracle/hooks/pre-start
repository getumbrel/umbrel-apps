#!/usr/bin/env bash

# Generate a unique server keypair on first start instead of shipping one
# committed keypair to every install. The package ships empty placeholder key
# files so the compose bind mounts have a source; on first start we replace them
# with a freshly generated, install-specific keypair. The pin server's generator
# skips if the key file already exists, so we remove the empty placeholders
# first. We require both files to be non-empty, otherwise an interrupted first
# run can leave one key written and skip regeneration forever. If generation
# fails we drop the partial files and bail out before compose runs, so the bind
# mounts never start with missing sources and the next start retries. Keys must
# exist before the containers start because the compose file bind-mounts the key
# files directly. Image is pinned to the same digest as the `node` service.
SERVER_KEY_FILE="${APP_DATA_DIR}/data/server_private_key.key"
SERVER_PUB_FILE="${APP_DATA_DIR}/data/server_public_key.pub"
if [[ ! -s "${SERVER_KEY_FILE}" || ! -s "${SERVER_PUB_FILE}" ]]; then
	echo "App: ${APP_ID} - Generating a unique server keypair..."
	rm -f "${SERVER_KEY_FILE}" "${SERVER_PUB_FILE}"
	docker run --rm \
		--entrypoint /usr/bin/python3 \
		--workdir /keys \
		--env PYTHONPATH=/ \
		--volume "${APP_DATA_DIR}/data:/keys" \
		tulipan81/blind_pin_server:v0.0.7@sha256:db8ce3f8de8da6cb083d60051a8ec720d5aa311e06148b259c42c4dfb7263c63 \
		-m pinserver.generateserverkey

	if [[ ! -s "${SERVER_KEY_FILE}" || ! -s "${SERVER_PUB_FILE}" ]]; then
		echo "App: ${APP_ID} - Key generation failed, aborting so it retries next start"
		rm -f "${SERVER_KEY_FILE}" "${SERVER_PUB_FILE}"
		exit 1
	fi
fi

# Create hidden service for the node container and ensure the web container
# gets the hidden service environment variable on first install.

HIDDEN_SERVICE_FILE="${TOR_DATA_DIR}/app-${APP_ID}-node/hostname"

if [[ -f "${HIDDEN_SERVICE_FILE}" ]]; then
	exit
fi

# Start web container first to update secret
"${UMBREL_ROOT}/scripts/app" compose "${APP_ID}" up --detach web

# Start node container so that a hidden service can be created
"${UMBREL_ROOT}/scripts/app" compose "${APP_ID}" up --detach node

echo "App: ${APP_ID} - Generating Tor Hidden Service for node container..."
"${UMBREL_ROOT}/scripts/app" compose "${APP_ID}" up --detach tor

for attempt in $(seq 1 100); do
	if [[ -f "${HIDDEN_SERVICE_FILE}" ]]; then
		echo "App: ${APP_ID} - Hidden service file created successfully!"
		# restart web container to source the new hidden service env var
		echo "App: ${APP_ID} - Restarting web container..."
		"${UMBREL_ROOT}/scripts/app" compose "${APP_ID}" restart web
		break
	fi
	sleep 0.1
done

if [[ ! -f "${HIDDEN_SERVICE_FILE}" ]]; then
	echo "App: ${APP_ID} - Hidden service file wasn't created"
fi