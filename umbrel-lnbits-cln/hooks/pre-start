#!/usr/bin/env bash
# =============================================================================
# umbrel-lnbits-cln hooks/pre-start
# =============================================================================
# Creates fine-grained CLNRest runes for LNbits on first boot.
# Runes persist in ${APP_DATA_DIR}/data/.clnrest-runes so they survive restarts.
# Requires manifestVersion: 1.1 and core-lightning as a dependency.
# =============================================================================

set -euo pipefail

CLN_CONTAINER="core-lightning_lightningd_1"
RUNE_CACHE="${APP_DATA_DIR}/data/.clnrest-runes"

# If runes already exist, skip creation
if [[ -f "${RUNE_CACHE}" ]]; then
	echo "App: ${APP_ID} - CLNRest runes already provisioned, skipping."
	exit 0
fi

echo "App: ${APP_ID} - Creating fine-grained CLNRest runes..."

# Wait for CLN to be responsive (dependency should ensure it, but be safe)
for attempt in $(seq 1 30); do
	if docker exec "${CLN_CONTAINER}" lightning-cli getinfo >/dev/null 2>&1; then
		break
	fi
	if [[ "${attempt}" -eq 30 ]]; then
		echo "App: ${APP_ID} - ERROR: CLN not responsive after 30 attempts"
		exit 1
	fi
	sleep 2
done

# ---------------------------------------------------------------------------
# Rune restriction syntax:
#   Each restriction is an array of alternatives (OR'd within, AND'd across).
#   "method^list" = method starts with "list"
#   "method=pay"  = method equals "pay"
# ---------------------------------------------------------------------------

# Readonly rune: list*, get*, summary, waitanyinvoice, waitinvoice
READONLY_RESTRICTIONS='[["method^list","method^get","method=summary","method=waitanyinvoice","method=waitinvoice"]]'

# Invoice rune: invoice, waitanyinvoice, waitinvoice, listinvoices
INVOICE_RESTRICTIONS='[["method=invoice","method=waitanyinvoice","method=waitinvoice","method=listinvoices"]]'

# Pay rune: pay, keysend, waitsendpay, listsendpays, listpays
PAY_RESTRICTIONS='[["method=pay","method=keysend","method=waitsendpay","method=listsendpays","method=listpays"]]'

# Create each rune and extract the rune string (use sed for portability)
extract_rune() { sed -n 's/.*"rune"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p'; }

READONLY_RUNE=$(docker exec "${CLN_CONTAINER}" lightning-cli createrune restrictions="${READONLY_RESTRICTIONS}" | extract_rune)
INVOICE_RUNE=$(docker exec "${CLN_CONTAINER}" lightning-cli createrune restrictions="${INVOICE_RESTRICTIONS}" | extract_rune)
PAY_RUNE=$(docker exec "${CLN_CONTAINER}" lightning-cli createrune restrictions="${PAY_RESTRICTIONS}" | extract_rune)

# Validate all three runes were created
if [[ -z "${READONLY_RUNE}" || -z "${INVOICE_RUNE}" || -z "${PAY_RUNE}" ]]; then
	echo "App: ${APP_ID} - ERROR: Failed to create one or more runes"
	exit 1
fi

# Persist runes (sourced by exports.sh on subsequent starts)
cat > "${RUNE_CACHE}" <<EOF
# Auto-generated by umbrel-lnbits-cln hooks/pre-start
# Fine-grained CLNRest runes — do not edit manually
APP_LNBITS_CLN_READONLY_RUNE="${READONLY_RUNE}"
APP_LNBITS_CLN_INVOICE_RUNE="${INVOICE_RUNE}"
APP_LNBITS_CLN_PAY_RUNE="${PAY_RUNE}"
EOF

chmod 600 "${RUNE_CACHE}"

echo "App: ${APP_ID} - CLNRest runes created successfully:"
echo "  Readonly: method^list|method^get|method=summary|method=waitanyinvoice|method=waitinvoice"
echo "  Invoice:  method=invoice|method=waitanyinvoice|method=waitinvoice|method=listinvoices"
echo "  Pay:      method=pay|method=keysend|method=waitsendpay|method=listsendpays|method=listpays"
