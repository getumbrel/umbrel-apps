# Force LF line endings for shell scripts and hook files on all platforms.
# Prevents Windows core.autocrlf from converting to CRLF on checkout,
# which breaks ShellCheck and shell execution on Linux (Pi5/umbrelOS).

*.sh        text eol=lf
exports.sh  text eol=lf
pre-start   text eol=lf
torrc.template text eol=lf
Dockerfile  text eol=lf

# Normalise other text files
*.yml       text eol=lf
*.yaml      text eol=lf
*.md        text eol=lf
*.json      text eol=lf
*.toml      text eol=lf
