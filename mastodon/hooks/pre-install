#!/usr/bin/env bash
set -euo pipefail

APP_DIR="$(readlink -f "$(dirname "${BASH_SOURCE[0]}")/..")"
APP_DATA_DIR="${APP_DATA_DIR:-${APP_DIR}}"

mkdir -p \
  "${APP_DATA_DIR}/data/system" \
  "${APP_DATA_DIR}/data/db" \
  "${APP_DATA_DIR}/data/redis"

touch "${APP_DATA_DIR}/mastodon.env"

if [[ "$(id -u)" -eq 0 ]]; then
  chown -R 1000:1000 \
    "${APP_DATA_DIR}/data/system" \
    "${APP_DATA_DIR}/data/db" \
    "${APP_DATA_DIR}/data/redis" \
    2>/dev/null || true
fi
